<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_back"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="20sp"
        android:textColor="@color/kubli_btn_dark"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbarDivider"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp"> <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#808080"
            android:layout_marginTop="24dp"
            android:layout_marginStart="24dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/rowNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/icNotif"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_notification"
                            app:tint="@color/kubli_btn_dark"
                            android:background="@drawable/bg_rounded_icon"
                            android:padding="8dp"
                            android:layout_centerVertical="true"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notification Preferences"
                            android:textSize="16sp"
                            android:textColor="#616161"
                            android:layout_toEndOf="@id/icNotif"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#9CA3AF"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

                    <RelativeLayout
                        android:id="@+id/rowLinkedAccounts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/icLink"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_linkacc"
                            app:tint="@color/kubli_btn_dark"
                            android:background="@drawable/bg_rounded_icon"
                            android:padding="8dp"
                            android:layout_centerVertical="true"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Linked Accounts"
                            android:textSize="16sp"
                            android:textColor="#616161"
                            android:layout_toEndOf="@id/icLink"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#9CA3AF"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPEARANCE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#808080"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:id="@+id/rowDarkMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/icMoon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_darkmode"
                        app:tint="@color/kubli_btn_dark"
                        android:background="@drawable/bg_rounded_icon"
                        android:padding="8dp"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dark mode"
                        android:textSize="16sp"
                        android:textColor="#616161"
                        android:layout_toEndOf="@id/icMoon"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEGAL"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#808080"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/rowTerms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/icDoc"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_termsofs"
                            app:tint="@color/kubli_btn_dark"
                            android:background="@drawable/bg_rounded_icon"
                            android:padding="8dp"
                            android:layout_centerVertical="true"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Terms of Service"
                            android:textSize="16sp"
                            android:textColor="#616161"
                            android:layout_toEndOf="@id/icDoc"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#9CA3AF"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

                    <RelativeLayout
                        android:id="@+id/rowPrivacy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/icShield"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_privacypolicy"
                            app:tint="@color/kubli_btn_dark"
                            android:background="@drawable/bg_rounded_icon"
                            android:padding="8dp"
                            android:layout_centerVertical="true"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Privacy Policy"
                            android:textSize="16sp"
                            android:textColor="#616161"
                            android:layout_toEndOf="@id/icShield"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#9CA3AF"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABOUT"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#808080"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/rowVersion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/icInfo"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_privacypolicy"
                            app:tint="@color/kubli_btn_dark"
                            android:background="@drawable/bg_rounded_icon"
                            android:padding="8dp"
                            android:layout_centerVertical="true"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="App Version"
                            android:textSize="16sp"
                            android:textColor="#616161"
                            android:layout_toEndOf="@id/icInfo"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#9CA3AF"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

                    <RelativeLayout
                        android:id="@+id/rowContact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/icMail"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_contactmail"
                            app:tint="@color/kubli_btn_dark"
                            android:background="@drawable/bg_rounded_icon"
                            android:padding="8dp"
                            android:layout_centerVertical="true"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact Us"
                            android:textSize="16sp"
                            android:textColor="#616161"
                            android:layout_toEndOf="@id/icMail"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="#9CA3AF"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Developed with privacy in mind\nBy Quaddrifoglio @ 2026"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavigationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="35dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#F8F9FA"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@android:color/transparent"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/nav_item_colors"
            app:itemTextColor="@color/nav_item_colors"
            app:itemTextAppearanceActive="@style/BottomNavTextSize"
            app:itemTextAppearanceInactive="@style/BottomNavTextSize"
            app:labelVisibilityMode="selected"
            app:itemIconSize="24dp"
            app:itemPaddingTop="8dp"
            app:itemPaddingBottom="8dp"
            app:elevation="0dp" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>